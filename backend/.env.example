# ── App ──────────────────────────────────────────────
APP_NAME=Jansewa AI
DEBUG=true

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jansewa
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/jansewa

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── AI API Keys ─────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_VISION_ENABLED=true
# For Google Vision, set GOOGLE_APPLICATION_CREDENTIALS to your service-account JSON path.

# ── External Services ───────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_SMS_FROM=+10000000000
TWILIO_WHATSAPP_FROM=whatsapp:+10000000000

# ── Cloudinary ──────────────────────────────────────
CLOUDINARY_URL=cloudinary://key:secret@cloud_name

# ── CORS ────────────────────────────────────────────
# Comma-separated origins handled in config.py
